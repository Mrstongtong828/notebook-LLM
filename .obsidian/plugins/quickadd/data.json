{
  "choices": [
    {
      "id": "capture-inbox-idea",
      "name": "捕获：快速想法到 Inbox",
      "type": "Capture",
      "command": true,
      "capture": {
        "captureTo": "00_Inbox/快速想法.md",
        "createFileIfItDoesntExist": true,
        "insertAtEnd": true,
        "format": "- {{DATE:YYYY-MM-DD HH:mm}} {{VALUE}}\n"
      },
      "fileOpening": {
        "location": "tab",
        "direction": "vertical",
        "mode": "default",
        "focus": true
      }
    },
    {
      "id": "capture-github-candidate",
      "name": "捕获：GitHub 项目候选",
      "type": "Capture",
      "command": true,
      "capture": {
        "captureTo": "00_Inbox/GitHub项目候选.md",
        "createFileIfItDoesntExist": true,
        "insertAtEnd": true,
        "format": "- {{DATE:YYYY-MM-DD}} {{VALUE}}\n  - 为什么收藏：\n  - 可能服务：\n  - 下一步：\n"
      },
      "fileOpening": {
        "location": "tab",
        "direction": "vertical",
        "mode": "default",
        "focus": true
      }
    },
    {
      "id": "template-wiki-topic",
      "name": "新建：Wiki 主题页",
      "type": "Template",
      "command": true,
      "template": {
        "templatePath": "99_Templates/Wiki主题页模板.md",
        "fileNameFormat": {
          "enabled": false,
          "format": ""
        },
        "folder": {
          "enabled": true,
          "folders": [
            "02_Wiki"
          ]
        },
        "appendLink": false,
        "openFileInNewTab": {
          "enabled": true,
          "direction": "vertical"
        }
      },
      "fileExistsBehavior": {
        "kind": "prompt"
      },
      "fileOpening": {
        "location": "tab",
        "direction": "vertical",
        "mode": "default",
        "focus": true
      }
    },
    {
      "id": "template-project",
      "name": "新建：项目页",
      "type": "Template",
      "command": true,
      "template": {
        "templatePath": "99_Templates/项目页模板.md",
        "fileNameFormat": {
          "enabled": false,
          "format": ""
        },
        "folder": {
          "enabled": true,
          "folders": [
            "03_Projects"
          ]
        },
        "appendLink": false,
        "openFileInNewTab": {
          "enabled": true,
          "direction": "vertical"
        }
      },
      "fileExistsBehavior": {
        "kind": "prompt"
      },
      "fileOpening": {
        "location": "tab",
        "direction": "vertical",
        "mode": "default",
        "focus": true
      }
    },
      {
        "id": "template-study-card",
        "name": "新建：课程学习卡",
        "type": "Template",
        "command": true,
        "template": {
          "templatePath": "99_Templates/课程学习卡模板.md",
          "fileNameFormat": {
            "enabled": true,
            "format": "{{VALUE}}-本周学习卡"
          },
          "folder": {
            "enabled": true,
            "folders": [
              "课程学习"
            ]
          },
          "appendLink": false,
          "openFileInNewTab": {
            "enabled": true,
            "direction": "vertical"
          }
        },
        "fileExistsBehavior": {
          "kind": "prompt"
        },
        "fileOpening": {
          "location": "tab",
          "direction": "vertical",
          "mode": "default",
          "focus": true
        }
      }
  ],
  "inputPrompt": "single-line",
  "persistInputPromptDrafts": true,
  "useSelectionAsCaptureValue": true,
  "devMode": false,
  "templateFolderPath": "99_Templates",
  "announceUpdates": "all",
  "version": "2.12.3",
  "globalVariables": {},
  "onePageInputEnabled": false,
  "disableOnlineFeatures": true,
  "enableRibbonIcon": false,
  "showCaptureNotification": true,
  "showInputCancellationNotification": false,
  "enableTemplatePropertyTypes": false,
  "dateAliases": {
    "t": "today",
    "tm": "tomorrow",
    "yd": "yesterday",
    "nw": "next week",
    "nm": "next month",
    "ny": "next year",
    "lw": "last week",
    "lm": "last month",
    "ly": "last year"
  },
  "ai": {
    "defaultModel": "Ask me",
    "defaultSystemPrompt": "As an AI assistant within Obsidian, your primary goal is to help users manage their ideas and knowledge more effectively. Format your responses using Markdown syntax. Please use the [[Obsidian]] link format. You can write aliases for the links by writing [[Obsidian|the alias after the pipe symbol]]. To use mathematical notation, use LaTeX syntax. LaTeX syntax for larger equations should be on separate lines, surrounded with double dollar signs ($$). You can also inline math expressions by wrapping it in $ symbols. For example, use $$w_{ij}^{\\text{new}}:=w_{ij}^{\\text{current}}+\\eta\\cdot\\delta_j\\cdot x_{ij}$$ on a separate line, but you can write \"($\\eta$ = learning rate, $\\delta_j$ = error term, $x_{ij}$ = input)\" inline.",
    "promptTemplatesFolderPath": "",
    "showAssistant": true,
